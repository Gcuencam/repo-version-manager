{
  "name": "repo-version-manager",
  "version": "1.0.0",
  "description": "Interactive CLI to manage the global version of a repo or monorepo and the individual version of each of its services, with git integration (branches, tags, rebase)",
  "keywords": [
    "repo",
    "monorepo",
    "version",
    "semver",
    "release",
    "cli"
  ],
  "license": "MIT",
  "author": "Gabriel Cuenca <gcuencamoncin@gmail.com> (https://github.com/Gcuencam)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gcuencam/monorepo-version-manager.git"
  },
  "homepage": "https://github.com/Gcuencam/monorepo-version-manager#readme",
  "bugs": {
    "url": "https://github.com/Gcuencam/monorepo-version-manager/issues"
  },
  "type": "module",
  "bin": {
    "rpvm": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.19"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "picocolors": "^1.1.1",
    "semver": "^7.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/semver": "^7.5.8",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
